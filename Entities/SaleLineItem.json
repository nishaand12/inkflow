{
  "name": "SaleLineItem",
  "type": "object",
  "properties": {
    "studio_id": { "type": "string", "description": "Studio ID" },
    "sale_id": { "type": "string", "description": "FK to sales" },
    "line_type": {
      "type": "string",
      "enum": ["service", "product", "adjustment", "gift_card"],
      "default": "product"
    },
    "reporting_category_id": { "type": "string", "description": "FK to reporting_categories" },
    "reporting_category_name": { "type": "string", "description": "Snapshot of category name at sale time" },
    "product_id": { "type": "string", "description": "FK to products (if product line)" },
    "description": { "type": "string" },
    "quantity": { "type": "number", "default": 1 },
    "unit_price": { "type": "number", "default": 0 },
    "discount_amount": { "type": "number", "default": 0 },
    "tax_rate": { "type": "number", "default": 0 },
    "tax_inclusive": { "type": "boolean", "default": false },
    "net_amount": { "type": "number", "default": 0, "description": "Signed pre-tax net (canonical)" },
    "tax_amount": { "type": "number", "default": 0, "description": "Exact per-line tax" },
    "line_total": { "type": "number", "default": 0, "description": "net_amount + tax_amount" },
    "revenue_sign": { "type": "integer", "default": 1, "description": "+1 normal, -1 negative-revenue" }
  },
  "required": ["studio_id", "sale_id", "description"],
  "rls": {
    "read": { "data.studio_id": "{{user.data.studio_id}}" },
    "update": { "data.studio_id": "{{user.data.studio_id}}" },
    "delete": { "data.studio_id": "{{user.data.studio_id}}" },
    "write": {}
  }
}
