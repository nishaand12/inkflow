{
  "name": "Product",
  "type": "object",
  "properties": {
    "studio_id": { "type": "string", "description": "Studio ID" },
    "reporting_category_id": { "type": "string", "description": "FK to reporting_categories" },
    "name": { "type": "string", "description": "Product name" },
    "supplier_name": { "type": "string", "description": "Vendor or distributor name for reordering" },
    "supplier_sku": { "type": "string", "description": "Supplier or manufacturer part number for reordering" },
    "sku": { "type": "string", "description": "Stock-keeping unit code" },
    "barcode": { "type": "string", "description": "Barcode value (scanner input)" },
    "price": { "type": "number", "default": 0, "description": "Retail price" },
    "cost": { "type": "number", "description": "Cost price (optional)" },
    "stock_quantity": { "type": "number", "description": "Counted on-hand units; omit or null when not tracking inventory" },
    "tax_rate": { "type": "number", "default": 0.13, "description": "Decimal sales tax rate (e.g. 0.13 for 13%); 0 for exempt items" },
    "is_active": { "type": "boolean", "default": true, "description": "Whether product is available for sale" }
  },
  "required": ["studio_id", "name", "price"],
  "rls": {
    "read": { "data.studio_id": "{{user.data.studio_id}}" },
    "update": { "data.studio_id": "{{user.data.studio_id}}", "user_condition": { "data.user_role": ["Owner", "Admin"] } },
    "delete": { "data.studio_id": "{{user.data.studio_id}}", "user_condition": { "data.user_role": ["Owner", "Admin"] } },
    "write": { "user_condition": { "data.user_role": ["Owner", "Admin"] } }
  }
}