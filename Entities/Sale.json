{
  "name": "Sale",
  "type": "object",
  "properties": {
    "studio_id": { "type": "string", "description": "Studio ID" },
    "location_id": { "type": "string", "description": "FK to locations" },
    "artist_id": { "type": "string", "description": "FK to artists (nullable for retail)" },
    "customer_id": { "type": "string", "description": "FK to customers (nullable for retail)" },
    "appointment_id": { "type": "string", "description": "FK to appointments (nullable for standalone sales)" },
    "sale_date": { "type": "string", "format": "date", "description": "Studio-local date revenue is recognized" },
    "status": { "type": "string", "enum": ["open", "completed", "voided"], "default": "completed" },
    "subtotal": { "type": "number", "default": 0, "description": "Sum of line net_amount (pre-tax)" },
    "tax_total": { "type": "number", "default": 0 },
    "discount_total": { "type": "number", "default": 0 },
    "tip_total": { "type": "number", "default": 0 },
    "total": { "type": "number", "default": 0, "description": "subtotal + tax_total + tip_total" },
    "artist_share": { "type": "number", "default": 0, "description": "Artist commission accrued for this sale; posted per-day at reconciliation close" },
    "notes": { "type": "string" },
    "created_by": { "type": "string" }
  },
  "required": ["studio_id", "sale_date"],
  "rls": {
    "read": { "data.studio_id": "{{user.data.studio_id}}" },
    "update": { "data.studio_id": "{{user.data.studio_id}}" },
    "delete": { "data.studio_id": "{{user.data.studio_id}}", "user_condition": { "data.user_role": ["Owner", "Admin"] } },
    "write": {}
  }
}
