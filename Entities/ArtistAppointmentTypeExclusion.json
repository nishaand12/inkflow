{
  "name": "ArtistAppointmentTypeExclusion",
  "type": "object",
  "properties": {
    "studio_id": { "type": "string", "description": "Studio ID" },
    "artist_id": { "type": "string", "description": "Artist who cannot be booked for this appointment type" },
    "appointment_type_id": { "type": "string", "description": "Appointment type excluded for this artist" },
    "created_at": { "type": "string", "format": "date-time" }
  },
  "required": ["studio_id", "artist_id", "appointment_type_id"],
  "rls": {
    "read": { "data.studio_id": "{{user.data.studio_id}}" },
    "update": { "data.studio_id": "{{user.data.studio_id}}", "user_condition": { "data.user_role": ["Owner", "Admin"] } },
    "delete": { "data.studio_id": "{{user.data.studio_id}}", "user_condition": { "data.user_role": ["Owner", "Admin"] } },
    "write": { "user_condition": { "data.user_role": ["Owner", "Admin"] } }
  }
}
