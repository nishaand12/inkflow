{
    "name": "AppointmentType",
    "type": "object",
    "properties": {
      "studio_id": {
        "type": "string",
        "description": "Studio ID"
      },
      "category": {
        "type": "string",
        "description": "Denormalized display label from booking hierarchy leaf (derived from hierarchy name)"
      },
      "appointment_kind_category_id": {
        "type": "string",
        "description": "Required: leaf row in booking hierarchy (reporting_categories with category_role=appointment_kind)"
      },
      "name": {
        "type": "string",
        "description": "Appointment type name"
      },
      "description": {
        "type": "string",
        "description": "Detailed description"
      },
      "default_duration_minutes": {
        "type": "integer",
        "description": "Default duration in minutes"
      },
      "default_deposit": {
        "type": "number",
        "description": "Default deposit amount"
      },
      "service_cost": {
        "type": "number",
        "description": "Optional fixed service cost shown to customers at booking"
      },
      "is_active": {
        "type": "boolean",
        "default": true,
        "description": "Whether appointment type is active"
      }
    },
    "required": [
      "studio_id",
      "name",
      "default_duration_minutes",
      "default_deposit"
    ],
    "rls": {
      "read": {
        "data.studio_id": "{{user.data.studio_id}}"
      },
      "update": {
        "data.studio_id": "{{user.data.studio_id}}"
      },
      "delete": {
        "data.studio_id": "{{user.data.studio_id}}"
      },
      "write": {
        "data.studio_id": "{{user.data.studio_id}}"
      }
    }
  }