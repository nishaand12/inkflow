{
  "name": "Supply",
  "type": "object",
  "properties": {
    "studio_id": { "type": "string", "description": "Studio ID" },
    "item_name": { "type": "string", "description": "Supply item name" },
    "item_description": { "type": "string", "description": "Description of the supply item" },
    "supplier": { "type": "string", "description": "Supplier or vendor name" },
    "status": {
      "type": "string",
      "enum": ["In Stock", "Running Low", "Order Now", "Out of Stock", "Ordered"],
      "default": "In Stock",
      "description": "Current supply status"
    },
    "notes": { "type": "string", "description": "Additional notes" }
  },
  "required": ["studio_id", "item_name"],
  "rls": {
    "read": { "data.studio_id": "{{user.data.studio_id}}" },
    "write": { "data.studio_id": "{{user.data.studio_id}}" },
    "update": { "data.studio_id": "{{user.data.studio_id}}" },
    "delete": { "data.studio_id": "{{user.data.studio_id}}" }
  }
}
